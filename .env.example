# ============================================
# FIREBASE CONFIGURATION
# ============================================
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# DEVELOPMENT MODE
# ============================================
VITE_DEV_MODE=true

# ============================================
# DATA SOURCE
# ============================================
# Set to 'true' to use Firebase Firestore
# Set to 'false' to use localStorage (default)
VITE_USE_FIREBASE=false

# ============================================
# RECAPTCHA (anti-bot protection for login/register/reset)
# ============================================
# Get your site key at https://www.google.com/recaptcha/admin
# Required in production. In DEV mode, a Google test key is used as fallback.
# VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# ============================================
# EMAILJS (contact form)
# ============================================
# Get these credentials at https://www.emailjs.com/
# VITE_EMAILJS_SERVICE_ID=your_service_id
# VITE_EMAILJS_TEMPLATE_ID=your_template_id
# VITE_EMAILJS_PUBLIC_KEY=your_public_key

# ============================================
# ADMIN CONTACT (optional)
# ============================================
# Email shown in user-facing error messages (e.g. deactivated account notice).
# If empty, a generic message is displayed instead.
# VITE_ADMIN_EMAIL=admin@yourdomain.com

# ============================================
# IMAGEKIT (image storage and CDN)
# ============================================
# Get your credentials at https://imagekit.io/
# These are safe to expose to the frontend (public key only)
VITE_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id/
VITE_IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
VITE_IMAGEKIT_AUTHENTICATION_ENDPOINT=/.netlify/functions/imagekit-auth
VITE_IMAGEKIT_DELETE_ENDPOINT=/.netlify/functions/imagekit-delete

# ============================================
# ROLE LOOKUP TIMEOUT (optional)
# ============================================
# Max milliseconds to wait for Firestore role lookup before failing closed.
# Increase for slow networks (mobile/3G). Default: 5000
# VITE_ROLE_TIMEOUT_MS=5000